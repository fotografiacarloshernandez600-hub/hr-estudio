---
import { createClient } from "@sanity/client";

const client = createClient({
  projectId: "6df459fs",
  dataset: "production",
  useCdn: false,
  apiVersion: "2024-02-21",
});

// Fetch con respaldo: si Sanity falla, la página construye igual
let ajustes = null, servicios = [], fotos = [], testimonios = [];
try {
  ajustes = await client.fetch(`*[_type == "ajustes"][0]{
    "logo": logo.asset->url,
    "fondos": imagenesHero[].asset->url,
    "urlAntes": fotoAntes.asset->url,
    "urlDespues": fotoDespues.asset->url
  }`);
  servicios = await client.fetch(`*[_type == "servicio" && defined(slug.current)]{ nombre, "slug": slug.current, descripcionBreve, "urlFondo": imagenFondo.asset->url }`);
  fotos = await client.fetch(`*[_type == "sesion"]{ titulo, municipio, categoria, "url": portada.asset->url }`);
  testimonios = await client.fetch(`*[_type == "testimonio"]{ nombre, evento, texto } | order(_createdAt desc)[0...6]`);
} catch (e) {
  console.error("Error al conectar con Sanity:", e.message);
}

const fondosHero = ajustes?.fondos?.length ? ajustes.fondos : [];
const fotoAntes = ajustes?.urlAntes || "";
const fotoDespues = ajustes?.urlDespues || "";

// Etiquetas para filtros del portafolio (usa "categoria" si existe; si no, municipio)
const etiquetas = [...new Set(fotos.map((f) => f.categoria || f.municipio).filter(Boolean))];

const WHATSAPP = "529331641201";
const waLink = (msg) => `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(msg)}`;

const pasos = [
  { n: "01", t: "Cuéntanos tu evento", d: "Escríbenos por WhatsApp: fecha, lugar y tipo de evento. Te cotizamos el mismo día." },
  { n: "02", t: "Sesión o cobertura", d: "Llegamos antes, preparamos el equipo y capturamos cada momento sin que lo notes." },
  { n: "03", t: "Edición profesional", d: "Seleccionamos y retocamos cada foto cuidando color, luz y detalle." },
  { n: "04", t: "Entrega", d: "Recibes tu galería digital en alta resolución, lista para compartir e imprimir." },
];
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR Estudio | Fotografía y video profesional en Paraíso, Tabasco</title>
    <meta name="description" content="Fotografía profesional de bodas, XV años, bautizos y eventos sociales en Paraíso, Tabasco. Video con drone, fotografía de producto y mapeo aéreo. Cotiza por WhatsApp." />
    <link rel="canonical" href="https://hr-estudio-web.vercel.app/" />
    <meta property="og:title" content="HR Estudio | Fotografía profesional en Paraíso, Tabasco" />
    <meta property="og:description" content="Capturamos los momentos más importantes de tu vida: bodas, XV años, eventos sociales y tomas aéreas con drone." />
    {fondosHero[0] && <meta property="og:image" content={fondosHero[0]} />}
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style is:global>
        :root {
            --negro: #161412;
            --carbon: #1F1C19;
            --carbon-2: #26221E;
            --crema: #F4EFE6;
            --humo: #9B948A;
            --oro: #C5A059;
            --oro-claro: #E2C98F;
            --borde: rgba(197, 160, 89, 0.25);
        }
        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { background: var(--negro); color: var(--crema); font-family: 'Inter', sans-serif; margin: 0; overflow-x: hidden; }
        ::selection { background: var(--oro); color: var(--negro); }

        #progress-bar { position: fixed; top: 0; left: 0; height: 2px; background: var(--oro); z-index: 100000; width: 0%; }

        #custom-cursor { width: 18px; height: 18px; background: var(--oro); border-radius: 50%; position: fixed; pointer-events: none; z-index: 99999; mix-blend-mode: difference; display: none; }
        @media (pointer: fine) { #custom-cursor { display: block; } }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

        /* ===== Navbar ===== */
        .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; display: flex; align-items: center; justify-content: space-between; padding: 18px 32px; transition: background 0.4s, padding 0.4s, border-color 0.4s; border-bottom: 1px solid transparent; }
        .nav.scrolled { background: rgba(22, 20, 18, 0.92); backdrop-filter: blur(12px); padding: 12px 32px; border-color: var(--borde); }
        .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--crema); }
        .nav-logo img { height: 38px; }
        .nav-logo span { font-family: 'Playfair Display', serif; letter-spacing: 4px; font-size: 1rem; }
        .nav-links { display: flex; gap: 32px; align-items: center; }
        .nav-links a { color: var(--crema); text-decoration: none; font-size: 0.78rem; letter-spacing: 2.5px; text-transform: uppercase; opacity: 0.85; transition: 0.3s; }
        .nav-links a:hover { color: var(--oro); opacity: 1; }
        .nav-cta { border: 1px solid var(--oro); color: var(--oro) !important; padding: 9px 18px; border-radius: 50px; }
        .nav-cta:hover { background: var(--oro); color: var(--negro) !important; }
        .nav-burger { display: none; background: none; border: none; color: var(--crema); font-size: 1.6rem; cursor: pointer; padding: 4px 8px; }
        @media (max-width: 860px) {
            .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: rgba(22,20,18,0.97); flex-direction: column; padding: 28px 0; gap: 22px; border-bottom: 1px solid var(--borde); }
            .nav-links.open { display: flex; }
            .nav-burger { display: block; }
        }

        /* ===== Hero ===== */
        .hero { position: relative; height: 100vh; min-height: 600px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
        .hero-slide { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0; transition: opacity 1.8s ease; transform: scale(1.05); }
        .hero-slide.active { opacity: 1; animation: kenburns 9s ease-out forwards; }
        @keyframes kenburns { from { transform: scale(1.12); } to { transform: scale(1.0); } }
        .hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(22,20,18,0.55) 0%, rgba(22,20,18,0.25) 45%, rgba(22,20,18,0.85) 100%); }
        .hero-marco { position: absolute; inset: 22px; border: 1px solid var(--borde); pointer-events: none; z-index: 3; }
        .hero-inner { position: relative; z-index: 4; padding: 0 24px; }
        .hero-logo { width: 90px; margin-bottom: 18px; filter: drop-shadow(0 2px 14px rgba(0,0,0,0.5)); }
        .hero-eyebrow { letter-spacing: 5px; font-size: 0.75rem; text-transform: uppercase; color: var(--oro-claro); margin: 0 0 14px; }
        .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.6rem, 9vw, 5.8rem); font-weight: 400; letter-spacing: 12px; margin: 0; line-height: 1.05; }
        .hero h1 em { font-style: italic; color: var(--oro); }
        .hero-sub { max-width: 560px; margin: 22px auto 34px; line-height: 1.8; color: var(--crema); opacity: 0.85; font-weight: 300; }
        .hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        .btn { display: inline-block; padding: 15px 34px; border-radius: 50px; text-decoration: none; font-size: 0.78rem; letter-spacing: 2.5px; text-transform: uppercase; transition: 0.3s; }
        .btn-oro { background: var(--oro); color: var(--negro); }
        .btn-oro:hover { background: var(--oro-claro); transform: translateY(-2px); }
        .btn-ghost { border: 1px solid rgba(244,239,230,0.5); color: var(--crema); }
        .btn-ghost:hover { border-color: var(--oro); color: var(--oro); }
        .hero-scroll { position: absolute; bottom: 38px; left: 50%; transform: translateX(-50%); z-index: 4; color: var(--oro-claro); font-size: 1.4rem; animation: flotar 2.2s ease-in-out infinite; text-decoration: none; }
        @keyframes flotar { 0%,100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 10px); } }

        /* ===== Secciones ===== */
        .section { padding: 110px 0 30px; }
        .section-head { text-align: center; margin-bottom: 56px; }
        .section-eyebrow { letter-spacing: 5px; font-size: 0.72rem; text-transform: uppercase; color: var(--oro); display: block; margin-bottom: 12px; }
        .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.9rem, 4.5vw, 3rem); font-weight: 400; margin: 0; }

        /* ===== Servicios ===== */
        .servicios-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 22px; }
        .card-servicio { position: relative; border-radius: 14px; overflow: hidden; aspect-ratio: 4/5; display: flex; align-items: flex-end; text-decoration: none; border: 1px solid rgba(244,239,230,0.08); }
        .card-servicio img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease, filter 0.5s; }
        .card-servicio::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(22,20,18,0) 35%, rgba(22,20,18,0.92) 100%); }
        .card-servicio:hover img { transform: scale(1.07); }
        .card-body { position: relative; z-index: 2; padding: 26px; width: 100%; }
        .card-body h3 { font-family: 'Playfair Display', serif; color: var(--crema); font-size: 1.45rem; font-weight: 400; margin: 0 0 8px; }
        .card-body p { color: var(--humo); font-size: 0.88rem; line-height: 1.6; margin: 0 0 14px; font-weight: 300; }
        .card-link { color: var(--oro); font-size: 0.74rem; letter-spacing: 2.5px; text-transform: uppercase; }
        .card-link::after { content: " →"; transition: 0.3s; }
        .card-servicio:hover .card-link::after { padding-left: 6px; }

        /* ===== Antes / Después ===== */
        .comparison-slider { width: 100%; max-width: 920px; margin: 0 auto; position: relative; aspect-ratio: 16/9; overflow: hidden; border-radius: 14px; border: 1px solid var(--borde); cursor: ew-resize; }
        .comparison-slider img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; pointer-events: none; max-width: none; }
        .img-after-wrapper { z-index: 2; width: 50%; height: 100%; overflow: hidden; position: absolute; top: 0; left: 0; border-right: 2px solid var(--oro); }
        .img-after-wrapper img { width: 920px; max-width: 92vw; }
        .slider-handle { position: absolute; z-index: 3; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 44px; height: 44px; background: var(--oro); color: var(--negro); border-radius: 50%; display: flex; align-items: center; justify-content: center; pointer-events: none; font-size: 1.1rem; }
        .comp-tag { position: absolute; bottom: 14px; z-index: 3; font-size: 0.68rem; letter-spacing: 2px; text-transform: uppercase; background: rgba(22,20,18,0.75); color: var(--crema); padding: 6px 12px; border-radius: 50px; pointer-events: none; }

        /* ===== Portafolio ===== */
        .filtros { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 36px; }
        .chip { background: none; border: 1px solid rgba(244,239,230,0.25); color: var(--crema); padding: 9px 20px; border-radius: 50px; cursor: pointer; font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; transition: 0.3s; font-family: 'Inter', sans-serif; }
        .chip:hover { border-color: var(--oro); color: var(--oro); }
        .chip.active { background: var(--oro); border-color: var(--oro); color: var(--negro); }
        .gallery-grid { columns: 3 280px; column-gap: 14px; }
        .gallery-grid.art-mode img { filter: grayscale(1) contrast(1.15); }
        .gallery-item { break-inside: avoid; margin-bottom: 14px; border-radius: 10px; overflow: hidden; cursor: pointer; position: relative; background: var(--carbon); }
        .gallery-item img { width: 100%; display: block; transition: transform 0.6s ease, filter 0.5s; }
        .gallery-item:hover img { transform: scale(1.05); }
        .gallery-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(22,20,18,0.85)); display: flex; align-items: flex-end; padding: 16px; opacity: 0; transition: 0.35s; }
        .gallery-item:hover .gallery-overlay { opacity: 1; }
        .gallery-overlay span { color: var(--crema); font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; }
        .gallery-item.oculto { display: none; }

        /* ===== Testimonios ===== */
        .testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 22px; }
        .testi-card { background: var(--carbon); border: 1px solid rgba(244,239,230,0.07); border-radius: 14px; padding: 34px 30px; }
        .testi-card .comilla { font-family: 'Playfair Display', serif; color: var(--oro); font-size: 2.6rem; line-height: 0.5; display: block; margin-bottom: 18px; }
        .testi-card p { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.05rem; line-height: 1.7; margin: 0 0 20px; color: var(--crema); }
        .testi-card footer { font-size: 0.8rem; color: var(--humo); letter-spacing: 1px; }
        .testi-card footer strong { color: var(--oro-claro); font-weight: 600; }

        /* ===== Proceso ===== */
        .proceso-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 22px; }
        .paso { border-top: 1px solid var(--borde); padding-top: 24px; }
        .paso .num { font-family: 'Playfair Display', serif; color: var(--oro); font-size: 1.6rem; }
        .paso h3 { font-size: 1rem; letter-spacing: 1px; margin: 14px 0 10px; font-weight: 600; }
        .paso p { color: var(--humo); font-size: 0.88rem; line-height: 1.7; margin: 0; font-weight: 300; }

        /* ===== CTA banner ===== */
        .cta-banner { background: var(--carbon); border-top: 1px solid var(--borde); border-bottom: 1px solid var(--borde); text-align: center; padding: 90px 24px; margin-top: 110px; }
        .cta-banner h2 { font-family: 'Playfair Display', serif; font-weight: 400; font-size: clamp(1.8rem, 4vw, 2.7rem); margin: 0 0 12px; }
        .cta-banner h2 em { color: var(--oro); }
        .cta-banner p { color: var(--humo); margin: 0 0 34px; font-weight: 300; }

        /* ===== Contacto ===== */
        .contacto-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 50px; }
        .col-titulo { font-size: 0.74rem; margin-bottom: 24px; display: block; letter-spacing: 3px; text-transform: uppercase; color: var(--oro); }
        .mapa-iframe { width: 100%; border-radius: 14px; filter: grayscale(1) invert(0.9) contrast(0.9); transition: 0.5s; border: 1px solid var(--borde); }
        .mapa-iframe:hover { filter: none; }
        .contacto-col p { color: var(--humo); line-height: 1.8; font-weight: 300; font-size: 0.95rem; }
        .contacto-col p strong { color: var(--crema); }
        .link-social { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--crema); margin-bottom: 18px; transition: 0.3s; font-size: 0.95rem; }
        .link-social:hover { color: var(--oro); transform: translateX(8px); }
        .link-social svg { width: 22px; height: 22px; fill: var(--oro); flex-shrink: 0; }
        .footer-bar { text-align: center; margin-top: 70px; font-size: 0.72rem; color: var(--humo); letter-spacing: 2px; border-top: 1px solid rgba(244,239,230,0.08); padding: 28px 0 36px; }

        /* ===== WhatsApp flotante ===== */
        .wa-float { position: fixed; bottom: 26px; right: 26px; z-index: 5000; width: 58px; height: 58px; border-radius: 50%; background: #25D366; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(0,0,0,0.45); transition: transform 0.3s; }
        .wa-float:hover { transform: scale(1.1); }
        .wa-float svg { width: 30px; height: 30px; fill: white; }

        /* ===== Lightbox ===== */
        #modal-simple { display: none; position: fixed; inset: 0; background: rgba(12,11,10,0.96); z-index: 10000; justify-content: center; align-items: center; flex-direction: column; gap: 16px; }
        #modal-img { max-width: 92%; max-height: 82vh; border-radius: 6px; }
        #modal-caption { color: var(--humo); font-size: 0.78rem; letter-spacing: 2px; text-transform: uppercase; }
        .modal-nav { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: 1px solid var(--borde); color: var(--crema); width: 46px; height: 46px; border-radius: 50%; cursor: pointer; font-size: 1.2rem; transition: 0.3s; }
        .modal-nav:hover { border-color: var(--oro); color: var(--oro); }
        #modal-prev { left: 20px; } #modal-next { right: 20px; }
        #modal-close { position: absolute; top: 22px; right: 26px; background: none; border: none; color: var(--crema); font-size: 1.8rem; cursor: pointer; }

        .reveal { opacity: 0; transform: translateY(30px); transition: 0.7s ease-out; }
        .reveal.active { opacity: 1; transform: translateY(0); }

        @media (prefers-reduced-motion: reduce) {
            .hero-slide.active { animation: none; transform: none; }
            .hero-scroll { animation: none; }
            .reveal { opacity: 1; transform: none; transition: none; }
        }
    </style>
</head>
<body>

    <div id="progress-bar"></div>
    <div id="custom-cursor"></div>

    <nav class="nav" id="navbar">
        <a href="#" class="nav-logo">
            {ajustes?.logo && <img src={ajustes.logo} alt="HR Estudio" />}
            <span>HR ESTUDIO</span>
        </a>
        <div class="nav-links" id="nav-links">
            <a href="#servicios">Servicios</a>
            <a href="#edicion">Edición</a>
            <a href="#portafolio">Portafolio</a>
            <a href="#proceso">Proceso</a>
            <a href="#contacto">Contacto</a>
            <a href={waLink("Hola, quiero cotizar un evento")} class="nav-cta" target="_blank" rel="noopener">Cotizar</a>
        </div>
        <button class="nav-burger" id="nav-burger" aria-label="Abrir menú">☰</button>
    </nav>

    <header class="hero" id="inicio">
        {fondosHero.map((url, i) => (
            <div class={`hero-slide ${i === 0 ? "active" : ""}`} style={`background-image: url('${url}')`}></div>
        ))}
        <div class="hero-marco"></div>
        <div class="hero-inner">
            {ajustes?.logo && <img src={ajustes.logo} class="hero-logo" alt="Logo HR Estudio" />}
            <p class="hero-eyebrow">Fotografía y video · Paraíso, Tabasco</p>
            <h1>HR <em>Estudio</em></h1>
            <p class="hero-sub">
                Inmortalizamos los momentos más importantes de tu vida: bodas, XV años, eventos
                sociales y tomas aéreas con drone, cuidando cada detalle con calidad y creatividad.
            </p>
            <div class="hero-actions">
                <a href={waLink("Hola, quiero cotizar un evento con HR Estudio")} class="btn btn-oro" target="_blank" rel="noopener">Cotiza tu evento</a>
                <a href="#portafolio" class="btn btn-ghost">Ver portafolio</a>
            </div>
        </div>
        <a href="#servicios" class="hero-scroll" aria-label="Bajar a servicios">↓</a>
    </header>

    <main>
        <section class="section container" id="servicios">
            <div class="section-head reveal">
                <span class="section-eyebrow">Lo que hacemos</span>
                <h2 class="section-title">Nuestros servicios</h2>
            </div>
            <div class="servicios-grid">
                {servicios.map((s) => (
                    <a href={`/paquetes/${s.slug}`} class="card-servicio reveal">
                        <img src={s.urlFondo} alt={s.nombre} loading="lazy" />
                        <div class="card-body">
                            <h3>{s.nombre}</h3>
                            <p>{s.descripcionBreve}</p>
                            <span class="card-link">Ver paquetes</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        {fotoAntes && fotoDespues && (
        <section class="section container" id="edicion">
            <div class="section-head reveal">
                <span class="section-eyebrow">Antes y después</span>
                <h2 class="section-title">Edición profesional</h2>
            </div>
            <div class="comparison-slider reveal" id="comp-container">
                <img src={fotoAntes} alt="Foto original sin editar" />
                <div class="img-after-wrapper" id="after-wrap">
                    <img src={fotoDespues} alt="Foto con edición profesional" />
                </div>
                <div class="slider-handle" id="comp-handle">↔</div>
                <span class="comp-tag" style="left: 14px;">Editada</span>
                <span class="comp-tag" style="right: 14px;">Original</span>
            </div>
        </section>
        )}

        <section class="section container" id="portafolio">
            <div class="section-head reveal">
                <span class="section-eyebrow">Nuestro trabajo</span>
                <h2 class="section-title">Portafolio</h2>
            </div>
            <div class="filtros reveal">
                <button class="chip active" data-filtro="todo">Todo</button>
                {etiquetas.map((et) => (
                    <button class="chip" data-filtro={et}>{et}</button>
                ))}
                <button class="chip" id="btn-filtro">Blanco y negro</button>
            </div>
            <div class="gallery-grid" id="main-gallery">
                {fotos.map((f) => (
                    <div class="gallery-item reveal" data-etiqueta={f.categoria || f.municipio || ""} data-url={f.url} data-titulo={f.titulo || ""}>
                        <img src={f.url} alt={f.titulo} loading="lazy" />
                        <div class="gallery-overlay"><span>{f.titulo} · {f.municipio}</span></div>
                    </div>
                ))}
            </div>
        </section>

        {testimonios.length > 0 && (
        <section class="section container" id="testimonios">
            <div class="section-head reveal">
                <span class="section-eyebrow">Clientes felices</span>
                <h2 class="section-title">Lo que dicen de nosotros</h2>
            </div>
            <div class="testi-grid">
                {testimonios.map((t) => (
                    <article class="testi-card reveal">
                        <span class="comilla">"</span>
                        <p>{t.texto}</p>
                        <footer><strong>{t.nombre}</strong>{t.evento && ` · ${t.evento}`}</footer>
                    </article>
                ))}
            </div>
        </section>
        )}

        <section class="section container" id="proceso">
            <div class="section-head reveal">
                <span class="section-eyebrow">Así de fácil</span>
                <h2 class="section-title">¿Cómo trabajamos?</h2>
            </div>
            <div class="proceso-grid">
                {pasos.map((p) => (
                    <div class="paso reveal">
                        <span class="num">{p.n}</span>
                        <h3>{p.t}</h3>
