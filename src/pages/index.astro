    <div id="modal-simple">
        <button id="modal-close" aria-label="Cerrar">✕</button>
        <button class="modal-nav" id="modal-prev" aria-label="Foto anterior">←</button>
        <img id="modal-img" src="" alt="Foto ampliada" />
        <span id="modal-caption"></span>
        <button class="modal-nav" id="modal-next" aria-label="Foto siguiente">→</button>
    </div>

    <script is:inline>
        // Cursor personalizado
        const cursor = document.getElementById('custom-cursor');
        document.addEventListener('mousemove', (e) => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
            cursor.style.transform = 'translate(-50%, -50%)';
        });

        // Navbar con scroll + barra de progreso
        const nav = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            nav.classList.toggle('scrolled', window.scrollY > 60);
            const h = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            document.getElementById('progress-bar').style.width = (window.scrollY / h) * 100 + '%';
        });

        // Menú móvil
        const burger = document.getElementById('nav-burger');
        const navLinks = document.getElementById('nav-links');
        burger.addEventListener('click', () => navLinks.classList.toggle('open'));
        navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));

        // Slideshow del hero
        const slides = document.querySelectorAll('.hero-slide');
        if (slides.length > 1) {
            let actual = 0;
            setInterval(() => {
                slides[actual].classList.remove('active');
                actual = (actual + 1) % slides.length;
                slides[actual].classList.add('active');
            }, 6500);
        }

        // Comparador antes / después
        const compContainer = document.getElementById('comp-container');
        if (compContainer) {
            const afterWrap = document.getElementById('after-wrap');
            const compHandle = document.getElementById('comp-handle');
            function moverComp(e) {
                const x = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
                const rect = compContainer.getBoundingClientRect();
                const pos = ((x - rect.left) / rect.width) * 100;
                if (pos >= 0 && pos <= 100) {
                    afterWrap.style.width = pos + '%';
                    compHandle.style.left = pos + '%';
                }
            }
            compContainer.addEventListener('mousemove', moverComp);
            compContainer.addEventListener('touchmove', moverComp);
        }

        // Filtros de portafolio
        const items = [...document.querySelectorAll('.gallery-item')];
        document.querySelectorAll('.chip[data-filtro]').forEach(chip => {
            chip.addEventListener('click', () => {
                document.querySelectorAll('.chip[data-filtro]').forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
                const f = chip.dataset.filtro;
                items.forEach(it => it.classList.toggle('oculto', f !== 'todo' && it.dataset.etiqueta !== f));
            });
        });
        document.getElementById('btn-filtro')?.addEventListener('click', function() {
            const activo = document.getElementById('main-gallery').classList.toggle('art-mode');
            this.classList.toggle('active', activo);
            this.textContent = activo ? 'Color original' : 'Blanco y negro';
        });

        // Lightbox con navegación
        const modal = document.getElementById('modal-simple');
        const modalImg = document.getElementById('modal-img');
        const modalCap = document.getElementById('modal-caption');
        let idx = 0;
        function visibles() { return items.filter(i => !i.classList.contains('oculto')); }
        function mostrar(i) {
            const v = visibles();
            if (!v.length) return;
            idx = (i + v.length) % v.length;
            modalImg.src = v[idx].dataset.url;
            modalCap.textContent = v[idx].dataset.titulo;
            modal.style.display = 'flex';
        }
        items.forEach(it => it.addEventListener('click', () => mostrar(visibles().indexOf(it))));
        document.getElementById('modal-prev').addEventListener('click', (e) => { e.stopPropagation(); mostrar(idx - 1); });
        document.getElementById('modal-next').addEventListener('click', (e) => { e.stopPropagation(); mostrar(idx + 1); });
        document.getElementById('modal-close').addEventListener('click', () => modal.style.display = 'none');
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });
        document.addEventListener('keydown', (e) => {
            if (modal.style.display !== 'flex') return;
            if (e.key === 'Escape') modal.style.display = 'none';
            if (e.key === 'ArrowLeft') mostrar(idx - 1);
            if (e.key === 'ArrowRight') mostrar(idx + 1);
        });

        // Aparición al hacer scroll
        function reveal() {
            document.querySelectorAll('.reveal').forEach(r => {
                if (r.getBoundingClientRect().top < window.innerHeight - 50) r.classList.add('active');
            });
        }
        window.addEventListener('scroll', reveal);
        reveal();
    </script>
